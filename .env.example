# ─── MindTrace++ Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your values

# Anthropic API key (optional — enables AI-powered behavioral reports)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App secret key (change in production)
SECRET_KEY=mindtrace-dev-secret-change-in-prod

# Environment
ENVIRONMENT=development

# Redis (default values work with docker-compose)
REDIS_URL=redis://redis:6379

# ML service URLs (default values work with docker-compose)
ML_FACIAL_URL=http://ml-facial:8001
ML_SPEECH_URL=http://ml-speech:8002
ML_TEXT_URL=http://ml-text:8003
ML_MICRO_URL=http://ml-micro:8004
